# --- Arcade AI ---
# Your MCP Gateway URL from https://app.arcade.dev/mcp-gateways
ARCADE_GATEWAY_URL=

# --- LLM ---
# Pick the agent model — provider is auto-detected from the prefix.
#   gpt-5.4            OpenAI frontier (default)
#   gpt-5.4-mini       cheaper, faster, slightly worse
#   claude-sonnet-4-6  Claude alternative
#   claude-opus-4-7    highest-nuance Claude
AGENT_MODEL=gpt-5.4

# OpenAI key powers the agent (when AGENT_MODEL=gpt-*) AND the embeddings.
OPENAI_API_KEY=
# Anthropic key is only required if AGENT_MODEL starts with "claude-".
ANTHROPIC_API_KEY=

# Embedding model for the Qdrant memory layer.
#   text-embedding-3-large   3072 dim (default, higher quality)
#   text-embedding-3-small   1536 dim (6x cheaper, good enough for short summaries)
# Switching models requires re-embedding — drop the Qdrant collection
# and let the app recreate it on next catch-up.
EMBEDDING_MODEL=text-embedding-3-large

# --- App ---
PORT=8765

# --- App ---
# PORT is the only required app URL config. NEXT_PUBLIC_APP_URL and BETTER_AUTH_URL
# are automatically derived from PORT in next.config.ts.
# Only set these if you need to override (e.g., when using ngrok for ARCADE_CUSTOM_VERIFIER).
# NEXT_PUBLIC_APP_URL=https://your-ngrok-url.ngrok-free.app
# BETTER_AUTH_URL=https://your-ngrok-url.ngrok-free.app

# --- Database ---
DATABASE_URL=local.db       # SQLite file path (default: local.db)

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=          # Random secret for session signing; generate with: openssl rand -hex 32

# --- Custom User Verification (optional, recommended for production) ---
# ARCADE_CUSTOM_VERIFIER=true
# ARCADE_API_KEY=             # Get from https://app.arcade.dev/settings

# --- Qdrant memory layer (optional but demo-critical) ---
# Create a free cluster at https://cloud.qdrant.io and paste both values.
# Local docker alternative: http://localhost:6333 with no API key.
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=
# Collection name (defaults to "catchmeup_items" if unset)
# QDRANT_COLLECTION=catchmeup_items

# --- Contextual Access (optional) ---
# Shared bearer secret Arcade uses to call /api/arcade/hooks/*.
# Set this AND register a logic extension at https://app.arcade.dev pointing at
# your deployed app's URL. If unset, the hooks accept all requests (dev only).
# ARCADE_HOOKS_TOKEN=

# Internal domain used by the internal-only-outbound policy.
# Any outbound Gmail recipient NOT at this domain is blocked.
# INTERNAL_DOMAIN=arcade.dev
